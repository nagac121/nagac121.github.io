---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Profile | Naga">
	<div class="max-w-4xl mx-auto">
		<h1 class="text-3xl font-bold mb-8 text-white">Profile</h1>
		
		<section class="mb-8">
			<h2 class="text-2xl font-semibold mb-4 text-blue-400">Work Experience</h2>
			<p class="text-gray-300">
				14+ years in the tech industry, specializing in full-stack development, software architecture, and scalable web applications.
			</p>
		</section>
		
		<section>
			<h2 class="text-2xl font-semibold mb-4 text-blue-400">Education</h2>
			<p class="text-gray-300">
				MCA Graduate with a strong foundation in computer science and software engineering.
			</p>
		</section>
	</div>
</Layout>