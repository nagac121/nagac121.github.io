---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Naga">
	<div class="max-w-2xl mx-auto">
		<h1 class="text-3xl font-bold mb-8 text-white">Contact Me</h1>

		<p class="text-gray-300 mb-6">
			Fill out the form below and submit the form to send me an email. I will reply back as soon as possible. I look forward to hearing from you!
		</p>

		<form id="contact-form" action="https://formspree.io/f/mdaylvda" method="POST" class="space-y-4">
			<!-- Honeypot field for spam protection -->
			<div style="display: none;">
				<label>
					Don't fill this out if you're human:
					<input name="_gotcha" type="text">
				</label>
			</div>

			<div>
				<label for="name" class="block text-gray-300 mb-2">Name <span class="text-red-500">*</span></label>
				<input type="text" id="name" name="name" required class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>

			<div>
				<label for="organization" class="block text-gray-300 mb-2">Organization (Optional)</label>
				<input type="text" id="organization" name="organization" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>

			<div>
				<label for="email" class="block text-gray-300 mb-2">Email <span class="text-red-500">*</span></label>
				<input type="email" id="email" name="email" required class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>

			<div>
				<label for="phone" class="block text-gray-300 mb-2">Phone (Optional)</label>
				<input type="tel" id="phone" name="phone" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>

			<div>
				<label for="message" class="block text-gray-300 mb-2">Message <span class="text-red-500">*</span> (min 20, max 500 chars)</label>
				<textarea id="message" name="message" required minlength="20" maxlength="500" rows="5" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400 resize-none"></textarea>
				<p class="text-sm text-gray-400 mt-1">Please provide a detailed message (minimum 20 characters)</p>
			</div>

			<button type="submit" id="submit-button" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition">
				Submit
			</button>

			<!-- Form status messages -->
			<div id="form-status" class="hidden mt-4 p-4 rounded-lg"></div>


		</form>
	</div>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const form = document.getElementById('contact-form') as HTMLFormElement | null;
		const submitButton = document.getElementById('submit-button') as HTMLButtonElement | null;
		const formStatus = document.getElementById('form-status') as HTMLDivElement | null;

		// Exit early if form elements are not found
		if (!form || !submitButton || !formStatus) {
			console.error('Contact form elements not found');
			return;
		}

		form.addEventListener('submit', (e: SubmitEvent) => {
			e.preventDefault();

			// Create FormData object to get form values
			const formData = new FormData(form);

			// Get form values from FormData with proper null handling
			const nameInput = formData.get('name');
			const emailInput = formData.get('email');
			const organizationInput = formData.get('organization');
			const phoneInput = formData.get('phone');
			const messageInput = formData.get('message');

			const name = nameInput !== null ? String(nameInput).trim() : '';
			const email = emailInput !== null ? String(emailInput).trim() : '';
			const organization = organizationInput !== null ? String(organizationInput).trim() : '';
			const phone = phoneInput !== null ? String(phoneInput).trim() : '';
			const message = messageInput !== null ? String(messageInput).trim() : '';

			// Additional client-side validation for message length
			if (message.length < 20) {
				showStatus('Please provide a detailed message (minimum 20 characters)', 'error');
				return;
			}

			if (message.length > 500) {
				showStatus('Message too long (maximum 500 characters)', 'error');
				return;
			}

			// Disable button and show loading state
			submitButton.disabled = true;
			submitButton.textContent = 'Sending...';
			formStatus.classList.add('hidden');

			// Submit via Fetch API (AJAX)
			fetch(form.action, {
				method: 'POST',
				body: formData,
				headers: {
					'Accept': 'application/json'
				}
			})
			.then(response => {
				if (response.ok) {
					return response.json();
				} else {
					throw response;
				}
			})
			.then(data => {
				// Success
				showStatus(`Thank you, ${name}! Your message has been sent. I will reply to your email with the requested Information shortly.`, 'success');
				form.reset();
			})
			.catch(error => {
				// Handle error responses
				if (error.status === 402 || error.status === 429) {
					// Email service limit reached
					showStatus("Email can't be sent at this time", 'error');
				} else {
					showStatus('Sorry, there was an error sending your message. Please try again later.', 'error');
				}
			})
			.finally(() => {
				// Re-enable button
				submitButton.disabled = false;
				submitButton.textContent = 'Submit';
			});
		});

		function showStatus(message: string, type: 'success' | 'error' | 'error-limit' | 'default') {
			if (!formStatus) return;
			
			formStatus.textContent = message;
			formStatus.className = 'mt-4 p-4 rounded-lg';

			switch(type) {
				case 'success':
					formStatus.classList.add('bg-green-900', 'text-green-300', 'border', 'border-green-700');
					break;
				case 'error':
					formStatus.classList.add('bg-red-900', 'text-red-300', 'border', 'border-red-700');
					break;
				case 'error-limit':
					formStatus.classList.add('bg-orange-900', 'text-orange-300', 'border', 'border-orange-700');
					break;
				default:
					formStatus.classList.add('bg-gray-800', 'text-gray-300');
			}

			formStatus.classList.remove('hidden');
		}
	});
</script>