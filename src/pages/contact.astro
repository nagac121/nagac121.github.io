---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Naga">
	<div class="max-w-2xl mx-auto">
		<h1 class="text-3xl font-bold mb-8 text-white">Contact Me</h1>
		
		<p class="text-gray-300 mb-6">
			Fill out the form below. I will receive your email and reply with any requested documents mentioned in the message.
		</p>
		
		<form action="https://formspree.io/f/your_id" method="POST" class="space-y-4">
			<div>
				<label for="name" class="block text-gray-300 mb-2">Name (Optional)</label>
				<input type="text" id="name" name="name" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>
			
			<div>
				<label for="organization" class="block text-gray-300 mb-2">Organization (Optional)</label>
				<input type="text" id="organization" name="organization" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>
			
			<div>
				<label for="email" class="block text-gray-300 mb-2">Email (Mandatory)</label>
				<input type="email" id="email" name="email" required class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>
			
			<div>
				<label for="phone" class="block text-gray-300 mb-2">Phone (Optional)</label>
				<input type="tel" id="phone" name="phone" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400">
			</div>
			
			<div>
				<label for="message" class="block text-gray-300 mb-2">Message (Mandatory, max 500 chars)</label>
				<textarea id="message" name="message" required maxlength="500" rows="5" class="w-full p-3 bg-gray-800 border border-gray-600 rounded-lg text-white focus:outline-none focus:border-blue-400 resize-none"></textarea>
			</div>
			
			<button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition">
				Send Message
			</button>
		</form>
	</div>
</Layout>