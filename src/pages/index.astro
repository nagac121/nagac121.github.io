---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Naga">
	<section class="text-center py-20">
		<h1 class="text-4xl md:text-6xl font-bold mb-4 text-white">
			Senior Full-Stack & Agentic AI Engineer
		</h1>
		<div class="space-x-4 pt-6">
			<a href="/projects" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition">
				View Projects
			</a>
			<a href="/blog" class="bg-gray-700 hover:bg-gray-600 text-white px-6 py-3 rounded-lg font-semibold transition">
				Read Blog
			</a>
		</div>
	</section>
</Layout>
