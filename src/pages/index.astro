---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Naga Chaitanya">
	<section class="text-center py-20">
		<h1 class="text-4xl md:text-6xl font-bold mb-4 text-white">
			Senior Software Architect & Full-Stack Engineer
		</h1>
		<p class="text-xl md:text-2xl text-gray-300 mb-8">
			14+ years of experience in React, Node.js, and scaling web applications. Currently exploring Agentic AI and LangGraph.
		</p>
		<div class="space-x-4">
			<a href="/profile" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition">
				View Projects
			</a>
			<a href="/blog" class="bg-gray-700 hover:bg-gray-600 text-white px-6 py-3 rounded-lg font-semibold transition">
				Read Blog
			</a>
		</div>
	</section>
</Layout>