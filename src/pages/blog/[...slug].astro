---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | Naga Chaitanya`}>
  <article class="max-w-4xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-4 text-white">{post.data.title}</h1>
      <p class="text-gray-400">{post.data.pubDate.toLocaleDateString()}</p>
      <p class="text-gray-300 mt-2">{post.data.description}</p>
    </header>
    
    <div class="prose prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Layout>