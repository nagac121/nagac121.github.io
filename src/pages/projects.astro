---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects | Naga">
	<div class="max-w-4xl mx-auto">
		<h1 class="text-3xl font-bold mb-8 text-white">Projects</h1>
		
		<section class="mb-12">
			<h2 class="text-2xl font-semibold mb-4 text-blue-400">Market Intelligence Agentic System</h2>
			<p class="text-gray-300 mb-4">
				<a href="https://market-intel-agent.streamlit.app/" class="text-blue-400 hover:underline">Live Demo</a> | <a href="https://github.com/nagac121/market-intel-agent" class="text-blue-400 hover:underline">Source</a>
			</p>
			<ul class="text-gray-300 space-y-2 mb-4">
				<li><strong class="text-white">Objective:</strong> Investigated the efficacy of multi-agent orchestration for real-time strategic market analysis using high-speed inference models.</li>
				<li><strong class="text-white">Architectural Innovation:</strong> Engineered an autonomous research pipeline leveraging Groq (LLaMA-3) and Tavily AI to synthesize web-scale data into structured SWOT and competitor intelligence.</li>
				<li><strong class="text-white">Core Contribution:</strong> Implemented Human-in-the-Loop (HITL) steering mechanisms, allowing users to influence agent decision-making—a critical requirement for enterprise-grade AI reliability.</li>
			</ul>
			<p class="text-gray-400">
				<strong class="text-white">Technical Stack:</strong> Groq, Tavily, Streamlit, Agentic Search Patterns, Python.
			</p>
		</section>
	</div>
</Layout>